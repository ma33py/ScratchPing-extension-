{
  "manifest_version": 3,
  "name": "ScratchPing",
  "version": "1.1",
  "description": "See activity of scratch projects",
  "permissions": [
    "cookies",
    "notifications",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://scratch.mit.edu/*",
    "https://clouddata.scratch.mit.edu/*",
    "https://api.scratch.mit.edu/*",
    "wss://clouddata.turbowarp.org/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://scratch.mit.edu/projects/*",
        "https://turbowarp.org/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/icon16_normal.png"],
      "matches": ["https://scratch.mit.edu/*", "https://turbowarp.org/*"]
    }
  ]
}